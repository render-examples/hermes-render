# Hermes Agent on Render: environment variables
#
# This file documents every variable the Render Blueprint understands.
# Do NOT commit a filled-in copy of this file. On Render, set these
# values in the Dashboard under your service's "Environment" tab, or
# let `render.yaml` generate them.
#
# Copy of upstream defaults relevant to a Render deploy. The full
# upstream surface lives in the Hermes repo's .env.example:
# https://github.com/NousResearch/hermes-agent/blob/main/.env.example

# =============================================================================
# Render-managed (set by the Blueprint, no user action needed)
# =============================================================================

# Enables the dashboard side-process inside the gateway container.
HERMES_DASHBOARD=1

# Bind the dashboard to all interfaces so Render's load balancer can reach it.
# The entrypoint passes --insecure automatically when this is non-loopback.
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=10000

# Exposes the in-browser Chat tab (full Hermes TUI through PTY + xterm.js).
# This is how you talk to the agent from the dashboard without a host TTY.
HERMES_DASHBOARD_TUI=1

# Generated once at deploy time by the Blueprint. Not used directly by
# upstream Hermes today; reuse this value as API_SERVER_KEY if you opt
# into the OpenAI-compatible API server below.
HERMES_GATEWAY_TOKEN=

# =============================================================================
# OpenAI-compatible API server (off by default)
# =============================================================================
# Enable to expose `/v1/chat/completions` and friends so external clients
# (Open WebUI, LibreChat, your own code) can call Hermes over HTTP. The
# server binds to 0.0.0.0:8642 inside the container; this is NOT mapped
# to the public Render URL by default. If you want it reachable, you'd
# need to swap the dashboard port for it, or add a private service.
#
# API_SERVER_KEY is required when API_SERVER_HOST is non-loopback.
API_SERVER_ENABLED=false
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=
API_SERVER_CORS_ORIGINS=

# =============================================================================
# LLM provider keys (set at least one)
# =============================================================================
# OpenRouter routes to most providers behind one key (easiest starting point).
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Direct provider keys (all optional).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=

# =============================================================================
# Tool API keys (all optional)
# =============================================================================
# Web research and browsing.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
EXA_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

# Persistent user modeling (https://honcho.dev).
HONCHO_API_KEY=

# =============================================================================
# Messaging gateways (set tokens for the platforms you want connected)
# =============================================================================
# Telegram. With TELEGRAM_WEBHOOK_URL unset, the gateway uses long-polling,
# which works on Render without exposing extra ports.
# Get a token from @BotFather. Find your Telegram user ID with @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=

# Discord. Create a bot at https://discord.com/developers/applications,
# enable the Message Content Intent, and invite it with bot scope.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=

# Slack (Socket Mode). Both tokens required.
# https://api.slack.com/apps → "Basic Information" → app-level token (xapp-...)
# OAuth & Permissions → bot token (xoxb-...).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=
SLACK_HOME_CHANNEL=
